# ───────────────────────────────────────────
# App
# ───────────────────────────────────────────
APP_ENV=development                # change to "production" in prod
APP_PORT=8000
SECRET_KEY=your_super_secret_key_here  # fill in both dev and prod

# ───────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────

# DEV — fill individual parts (Docker)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=echomind_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PROD — fill this full URL (Railway/Render gives you this), leave blank in dev
DATABASE_URL=

# ───────────────────────────────────────────
# Redis
# ───────────────────────────────────────────

# DEV — fill individual parts (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PROD — fill this full URL, leave blank in dev
REDIS_URL=

# ───────────────────────────────────────────
# Qdrant
# ───────────────────────────────────────────

# DEV — fill individual parts (Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# PROD — fill this full URL, leave blank in dev
QDRANT_URL=

# ───────────────────────────────────────────
# OpenAI
# ───────────────────────────────────────────
OPENAI_API_KEY=     # fill in both dev and prod

# ───────────────────────────────────────────
# JWT
# ───────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here   # fill in both dev and prod
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7